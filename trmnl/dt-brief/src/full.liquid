<div class="layout">
  <div class="grid gap stretch-x">
    <div class="col--span-7">
      <span class="label label--medium group-header" data-group-header="true">Meetings</span>
      {% if meetings and meetings != empty %}
      <div class="columns">
        <div class="column">
          {% for m in meetings limit: 6 %}
          <div class="item">
            <div class="meta"></div>
            <div class="content">
              <span class="title title--small" data-clamp="1">{{ m.title }}</span>
              {% assign who = m.people | map: "name" | join: " · " %}
              {% if m.unmatched and m.unmatched != empty %}
                {% assign extra = m.unmatched | join: " · " %}
                {% if who == "" %}{% assign who = extra %}{% else %}{% assign who = who | append: " · " | append: extra %}{% endif %}
              {% endif %}
              {% if m.more_unmatched %}{% assign who = who | append: " +" | append: m.more_unmatched %}{% endif %}
              {% if who != "" %}<span class="description" data-clamp="1">{{ who }}</span>{% endif %}
              <div class="flex gap--xsmall">
                <span class="label label--small label--underline">{{ m.time }}</span>
                {% if m.people.first.role %}
                <span class="label label--small label--gray" data-clamp="1">{{ m.people.first.role }}{% if m.people.first.employer %} · {{ m.people.first.employer }}{% endif %}</span>
                {% endif %}
              </div>
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
      {% else %}
      <div class="item">
        <div class="meta"></div>
        <div class="content">
          <span class="title title--small">Clear calendar</span>
          <span class="description">No people-facing meetings today.</span>
        </div>
      </div>
      {% endif %}
    </div>
    <div class="col--span-5">
      {% if birthdays and birthdays != empty %}
      <span class="label label--medium group-header" data-group-header="true">Birthdays</span>
      {% for b in birthdays limit: 3 %}
      <div class="item">
        <div class="meta"></div>
        <div class="content">
          <div class="flex gap--xsmall">
            <span class="title title--small" data-clamp="1">{{ b.name }}</span>
            {% if b.today %}<span class="label label--small label--inverted">Today</span>{% endif %}
          </div>
          <span class="label label--small label--gray">{{ b.date | date: "%b %-d" }}{% if b.age %} · turns {{ b.age }}{% endif %}</span>
        </div>
      </div>
      {% endfor %}
      {% endif %}
      {% if reconnect and reconnect != empty %}
      <span class="label label--medium group-header" data-group-header="true">Reconnect</span>
      {% for r in reconnect limit: 3 %}
      <div class="item">
        <div class="meta"></div>
        <div class="content">
          <span class="title title--small" data-clamp="1">{{ r.name }}</span>
          <span class="label label--small label--gray">{% if r.days %}{{ r.days }} days ago{% else %}no contact logged{% endif %}{% if r.relationship != "" %} · {{ r.relationship }}{% endif %}</span>
        </div>
      </div>
      {% endfor %}
      {% endif %}
      {% if on_this_day and on_this_day != empty %}
      <span class="label label--medium group-header" data-group-header="true">On This Day</span>
      {% for o in on_this_day limit: 2 %}
      <div class="item">
        <div class="meta"></div>
        <div class="content">
          <span class="title title--small" data-clamp="1">{{ o.name }}</span>
          <span class="label label--small label--gray">{{ o.years }} {% if o.years == 1 %}year{% else %}years{% endif %} ago{% if o.kind != "" %} · {{ o.kind }}{% endif %}</span>
        </div>
      </div>
      {% endfor %}
      {% endif %}
      {% if journal %}
      <span class="label label--small label--gray" data-clamp="2">
        {%- case journal.state -%}
        {%- when "pending" -%}Journal: yesterday's entry is pending OCR
        {%- when "parked" -%}Journal: {{ journal.parked }} page{% if journal.parked != 1 %}s{% endif %} parked
        {%- else -%}Journal: no entry arrived for yesterday
        {%- endcase -%}
      </span>
      {% endif %}
      {% if review and review.pending > 0 %}
      <span class="label label--small label--gray">Entity review: {{ review.pending }} proposal{% if review.pending != 1 %}s{% endif %} waiting{% if review.parked > 0 %} · {{ review.parked }} parked{% endif %}</span>
      {% endif %}
    </div>
  </div>
</div>

<div class="title_bar">
  <img class="image" src="https://trmnl.com/images/plugins/trmnl--render.svg">
  <span class="title">Daily Brief</span>
  <span class="instance">{{ date | date: "%A, %B %-d" }}</span>
</div>
