<div class="layout layout--center-y">
  <div class="grid grid--cols-12 gap stretch-x">
    <div class="col--span-7">
      <div class="stretch-x">
      <span class="label label--medium">Today</span>
      {% assign shown_meetings = meetings.size %}
      {% if shown_meetings > 5 %}{% assign shown_meetings = 5 %}{% endif %}
      {% assign hidden_meetings = meetings.size | minus: shown_meetings %}
      {% if more_meetings %}{% assign hidden_meetings = hidden_meetings | plus: more_meetings %}{% endif %}
      {% assign show_meetings = false %}
      {% if meetings != empty %}{% assign show_meetings = true %}{% endif %}
      {% if hidden_meetings > 0 %}{% assign show_meetings = true %}{% endif %}
      {% if show_meetings %}
      {% for m in meetings limit: 5 %}
      <div class="item">
        <div class="meta"></div>
        <div class="content">
          <span class="title title--small" data-clamp="1">{{ m.title }}</span>
          {% assign who = m.people | map: "name" | join: " · " %}
          {% if m.unmatched and m.unmatched != empty %}
            {% assign extra = m.unmatched | join: " · " %}
            {% if who == "" %}{% assign who = extra %}{% else %}{% assign who = who | append: " · " | append: extra %}{% endif %}
          {% endif %}
          {% if m.more_unmatched %}{% assign who = who | append: " +" | append: m.more_unmatched %}{% endif %}
          {% if who != "" %}<span class="description" data-clamp="1">{{ who }}</span>{% endif %}
          <div class="flex gap--xsmall">
            <span class="label label--small label--underline">{{ m.time }}</span>
            {% if m.people.first.role %}
            <span class="label label--small label--gray" data-clamp="1">{{ m.people.first.role }}{% if m.people.first.employer %} · {{ m.people.first.employer }}{% endif %}</span>
            {% endif %}
          </div>
        </div>
      </div>
      {% endfor %}
      {% if hidden_meetings > 0 %}
      <span class="label label--small label--gray">+{{ hidden_meetings }} more later today</span>
      {% endif %}
      {% else %}
      <div class="item">
        <div class="meta"></div>
        <div class="content">
          <span class="title title--small">None</span>
          <span class="description">Nothing on the calendar today.</span>
        </div>
      </div>
      {% endif %}
      </div>
    </div>
    <div class="col--span-5">
      <div class="stretch-x">
      {% assign shown_birthdays = birthdays.size %}
      {% if shown_birthdays > 3 %}{% assign shown_birthdays = 3 %}{% endif %}
      {% assign hidden_birthdays = birthdays.size | minus: shown_birthdays %}
      {% if more_birthdays %}{% assign hidden_birthdays = hidden_birthdays | plus: more_birthdays %}{% endif %}
      {% assign show_birthdays = false %}
      {% if birthdays != empty %}{% assign show_birthdays = true %}{% endif %}
      {% if hidden_birthdays > 0 %}{% assign show_birthdays = true %}{% endif %}
      {% if show_birthdays %}
      <span class="label label--medium">Birthdays</span>
      {% for b in birthdays limit: 3 %}
      <div class="item">
        <div class="meta"></div>
        <div class="content">
          <span class="title title--small" data-clamp="1">{{ b.name }}</span>
          <div class="flex gap--xsmall">
            <span class="label label--small label--gray">{{ b.date | date: "%b %-d" }}{% if b.age %} · turns {{ b.age }}{% endif %}</span>
            {% if b.today %}<span class="label label--small label--inverted">today</span>{% endif %}
          </div>
        </div>
      </div>
      {% endfor %}
      {% if hidden_birthdays > 0 %}
      <span class="label label--small label--gray">+{{ hidden_birthdays }} more</span>
      {% endif %}
      <div class="divider"></div>
      {% endif %}
      {% assign shown_reconnect = reconnect.size %}
      {% if shown_reconnect > 3 %}{% assign shown_reconnect = 3 %}{% endif %}
      {% assign hidden_reconnect = reconnect.size | minus: shown_reconnect %}
      {% if more_reconnect %}{% assign hidden_reconnect = hidden_reconnect | plus: more_reconnect %}{% endif %}
      {% assign show_reconnect = false %}
      {% if reconnect != empty %}{% assign show_reconnect = true %}{% endif %}
      {% if hidden_reconnect > 0 %}{% assign show_reconnect = true %}{% endif %}
      {% if show_reconnect %}
      <span class="label label--medium">Reconnect</span>
      {% for r in reconnect limit: 3 %}
      <div class="item">
        <div class="meta"></div>
        <div class="content">
          <span class="title title--small" data-clamp="1">{{ r.name }}</span>
          <span class="label label--small label--gray">{% if r.days %}{{ r.days }} days ago{% else %}no contact logged{% endif %}{% if r.relationship != "" %} · {{ r.relationship }}{% endif %}</span>
        </div>
      </div>
      {% endfor %}
      {% if hidden_reconnect > 0 %}
      <span class="label label--small label--gray">+{{ hidden_reconnect }} more overdue</span>
      {% endif %}
      <div class="divider"></div>
      {% endif %}
      {% assign shown_on_this_day = on_this_day.size %}
      {% if shown_on_this_day > 2 %}{% assign shown_on_this_day = 2 %}{% endif %}
      {% assign hidden_on_this_day = on_this_day.size | minus: shown_on_this_day %}
      {% if more_on_this_day %}{% assign hidden_on_this_day = hidden_on_this_day | plus: more_on_this_day %}{% endif %}
      {% assign show_on_this_day = false %}
      {% if on_this_day != empty %}{% assign show_on_this_day = true %}{% endif %}
      {% if hidden_on_this_day > 0 %}{% assign show_on_this_day = true %}{% endif %}
      {% if show_on_this_day %}
      <span class="label label--medium">On This Day</span>
      {% for o in on_this_day limit: 2 %}
      <div class="item">
        <div class="meta"></div>
        <div class="content">
          <span class="title title--small" data-clamp="1">{{ o.name }}</span>
          <span class="label label--small label--gray">{{ o.years }} {% if o.years == 1 %}year{% else %}years{% endif %} ago{% if o.kind != "" %} · {{ o.kind }}{% endif %}</span>
        </div>
      </div>
      {% endfor %}
      {% if hidden_on_this_day > 0 %}
      <span class="label label--small label--gray">+{{ hidden_on_this_day }} more</span>
      {% endif %}
      {% endif %}
      {% if journal %}
      <span class="label label--small label--gray" data-clamp="2">
        {%- case journal.state -%}
        {%- when "pending" -%}Journal: yesterday's entry is pending OCR
        {%- when "parked" -%}Journal: {{ journal.parked }} page{% if journal.parked != 1 %}s{% endif %} parked
        {%- else -%}Journal: no entry arrived for yesterday
        {%- endcase -%}
      </span>
      {% endif %}
      {% if review and review.pending > 0 %}
      <span class="label label--small label--gray">Entity review: {{ review.pending }} proposal{% if review.pending != 1 %}s{% endif %} waiting{% if review.parked > 0 %} · {{ review.parked }} parked{% endif %}</span>
      {% endif %}
      </div>
    </div>
  </div>
</div>

<div class="title_bar">
  <img class="image image-stroke" src="data:image/svg+xml;base64,{{ svg_logo | base64_encode }}">
  <span class="title">Daily Brief</span>
  <span class="instance">{{ date | date: "%A, %B %-d" }}</span>
</div>
