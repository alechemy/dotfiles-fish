<div class="layout layout--center-y">
  <div class="grid grid--cols-12 gap stretch-x">
    <div class="col--span-6">
      <div class="stretch-x">
      <span class="label label--small">Today</span>
      {% assign shown_meetings = meetings.size %}
      {% if shown_meetings > 2 %}{% assign shown_meetings = 2 %}{% endif %}
      {% assign hidden_meetings = meetings.size | minus: shown_meetings %}
      {% if more_meetings %}{% assign hidden_meetings = hidden_meetings | plus: more_meetings %}{% endif %}
      {% assign show_meetings = false %}
      {% if meetings != empty %}{% assign show_meetings = true %}{% endif %}
      {% if hidden_meetings > 0 %}{% assign show_meetings = true %}{% endif %}
      {% if show_meetings %}
      {% for m in meetings limit: 2 %}
      <div class="item">
        <div class="meta"></div>
        <div class="content">
          <span class="title title--small" data-clamp="1">{{ m.title }}</span>
          <span class="label label--small label--underline">{{ m.time }}</span>
        </div>
      </div>
      {% endfor %}
      {% if hidden_meetings > 0 %}
      <span class="label label--small label--gray">+{{ hidden_meetings }} more later today</span>
      {% endif %}
      {% else %}
      <div class="item">
        <div class="meta"></div>
        <div class="content">
          <span class="title title--small">None</span>
          <span class="label label--small label--gray">Nothing scheduled</span>
        </div>
      </div>
      {% endif %}
      </div>
    </div>
    <div class="col--span-3">
      <div class="stretch-x">
      {% assign shown_birthdays = birthdays.size %}
      {% if shown_birthdays > 2 %}{% assign shown_birthdays = 2 %}{% endif %}
      {% assign hidden_birthdays = birthdays.size | minus: shown_birthdays %}
      {% if more_birthdays %}{% assign hidden_birthdays = hidden_birthdays | plus: more_birthdays %}{% endif %}
      {% assign show_birthdays = false %}
      {% if birthdays != empty %}{% assign show_birthdays = true %}{% endif %}
      {% if hidden_birthdays > 0 %}{% assign show_birthdays = true %}{% endif %}
      {% if show_birthdays %}
      <span class="label label--small">Birthdays</span>
      {% for b in birthdays limit: 2 %}
      <div class="item">
        <div class="meta"></div>
        <div class="content">
          <span class="title title--small" data-clamp="1">{{ b.name }}</span>
          <span class="label label--small label--gray">{{ b.date | date: "%b %-d" }}</span>
        </div>
      </div>
      {% endfor %}
      {% if hidden_birthdays > 0 %}
      <span class="label label--small label--gray">+{{ hidden_birthdays }} more</span>
      {% endif %}
      {% endif %}
      </div>
    </div>
    <div class="col--span-3">
      <div class="stretch-x">
      {% assign shown_reconnect = reconnect.size %}
      {% if shown_reconnect > 2 %}{% assign shown_reconnect = 2 %}{% endif %}
      {% assign hidden_reconnect = reconnect.size | minus: shown_reconnect %}
      {% if more_reconnect %}{% assign hidden_reconnect = hidden_reconnect | plus: more_reconnect %}{% endif %}
      {% assign show_reconnect = false %}
      {% if reconnect != empty %}{% assign show_reconnect = true %}{% endif %}
      {% if hidden_reconnect > 0 %}{% assign show_reconnect = true %}{% endif %}
      {% if show_reconnect %}
      <span class="label label--small">Reconnect</span>
      {% for r in reconnect limit: 2 %}
      <div class="item">
        <div class="meta"></div>
        <div class="content">
          <span class="title title--small" data-clamp="1">{{ r.name }}</span>
          <span class="label label--small label--gray">{% if r.days %}{{ r.days }}d{% else %}never{% endif %}</span>
        </div>
      </div>
      {% endfor %}
      {% if hidden_reconnect > 0 %}
      <span class="label label--small label--gray">+{{ hidden_reconnect }} more overdue</span>
      {% endif %}
      {% endif %}
      </div>
    </div>
  </div>
</div>

<div class="title_bar">
  <img class="image image-stroke" src="data:image/svg+xml;base64,{{ svg_logo | base64_encode }}">
  <span class="title">Daily Brief</span>
  <span class="instance">{{ date | date: "%b %-d" }}</span>
</div>
