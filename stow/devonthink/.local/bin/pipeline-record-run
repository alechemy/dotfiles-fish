#!/bin/bash
# pipeline-record-run <job-name> <expected-interval-seconds>
#
# Records the current run time for a pipeline job and logs an ALERT-level
# warning if the gap since the previous run exceeds 2x the expected interval.
# The gap is judged on awake time (awake-seconds): launchd's StartInterval
# does not fire while the machine is asleep, so on a laptop a lid-close nap
# or a day of travel is expected silence, not a stalled job. A sleep-covered
# gap is still logged, at INFO, so the history stays visible without paging.
#
# An interval of 0 records the run without ever alerting — for KeepAlive
# jobs that only call this at startup, where the gap since the previous
# call is just their (healthy) uptime, so any threshold false-alerts on
# every restart; dt-watchdog checks their liveness instead.
#
# Called as the first non-trivial action by each pipeline entry point.
# Writes timestamps to ~/.local/state/devonthink/<job>.last-run.

set -euo pipefail

JOB="${1:?missing job name}"
INTERVAL="${2:?missing interval seconds}"

STATE_DIR="$HOME/.local/state/devonthink"
STATE_FILE="$STATE_DIR/${JOB}.last-run"
PIPELINE_LOG="$HOME/.local/bin/pipeline-log"

mkdir -p "$STATE_DIR"

NOW=$(date +%s)

if [[ "$INTERVAL" -gt 0 && -f "$STATE_FILE" ]]; then
    LAST=$(cat "$STATE_FILE" 2>/dev/null || echo 0)
    if [[ "$LAST" =~ ^[0-9]+$ ]] && [[ "$LAST" -gt 0 ]]; then
        GAP=$((NOW - LAST))
        THRESHOLD=$((INTERVAL * 2))
        if [[ "$GAP" -gt "$THRESHOLD" ]]; then
            GAP_MIN=$((GAP / 60))
            EXPECTED_MIN=$((INTERVAL / 60))
            AWAKE=$("$HOME/.local/bin/awake-seconds" "$LAST" "$NOW" 2>/dev/null || true)
            [[ "$AWAKE" =~ ^[0-9]+$ ]] || AWAKE=$GAP
            if [[ "$AWAKE" -le "$THRESHOLD" ]]; then
                "$PIPELINE_LOG" "$JOB" INFO \
                    "gap of ${GAP_MIN}m since last run, awake for only $((AWAKE / 60))m of it (interval is ${EXPECTED_MIN}m)" \
                    || true
            else
                "$PIPELINE_LOG" "$JOB" WARN \
                    "ALERT: gap of ${GAP_MIN}m since last run (interval is ${EXPECTED_MIN}m)" \
                    || true
            fi
        fi
    fi
fi

echo "$NOW" > "$STATE_FILE"
