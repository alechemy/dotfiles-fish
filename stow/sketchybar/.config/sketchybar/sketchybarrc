# Front App
sketchybar --add item front_app left \
  --set front_app icon.drawing=off script="$PLUGIN_DIR/front_app.sh" \
  label.font="Helvetica Neue:Bold:14.0" \
  --subscribe front_app front_app_switched

# Auto-gaps on app hide — invisible helper, no UI. AeroSpace fires no callback
# when an app is hidden (Cmd-H), but macOS posts NSWorkspaceDidActivateApplication
# as the next app comes forward, which SketchyBar surfaces as front_app_switched.
# This item rides that event to recompute outer gaps. See plugins/aerospace_gaps.sh.
sketchybar --add item aerospace_gaps left \
  --set aerospace_gaps drawing=off script="$PLUGIN_DIR/aerospace_gaps.sh" \
  --subscribe aerospace_gaps front_app_switched

# Feishin Now Playing — leftmost
sketchybar --add item feishin right \
  --set feishin update_freq=5 \
  icon.font="Helvetica Neue:Regular:14.0" \
  icon=" Not playing" \
  label.font="Helvetica Neue:Bold:14.0" \
  label="" \
  label.padding_right=8 \
  click_script="$PLUGIN_DIR/feishin_click.sh" \
  script="$PLUGIN_DIR/feishin.sh"

##### Force all scripts to run the first time (never do this in a script) #####
sketchybar --update
sketchybar --trigger aerospace_workspace_change FOCUSED_WORKSPACE=$(aerospace list-workspaces --focused)
