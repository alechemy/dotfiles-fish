# SketchyBar config — Aerospace integration
# https://felixkratz.github.io/SketchyBar/config/bar

PLUGIN_DIR="$CONFIG_DIR/plugins"

##### Bar Appearance #####
# notch_width reserves a center gap on notched displays (MacBook built-in) so
# items in left/right positions don't render under the notch. Ignored on
# external displays, so the same config works clamshell or standalone.
sketchybar --bar position=top height=40 blur_radius=30 color=0x40000000 topmost=window_level notch_width=200

##### Changing Defaults #####
default=(
  padding_left=5
  padding_right=5
  icon.font="Helvetica Neue:Bold:17.0"
  label.font="Helvetica Neue:Regular:14.0"
  icon.color=0xffffffff
  label.color=0xffffffff
  icon.padding_left=4
  icon.padding_right=4
  label.padding_left=4
  label.padding_right=4
)
sketchybar --default "${default[@]}"

##### Right Items (added right-to-left: first = rightmost) #####

# Clock — furthest right
sketchybar --add item clock right \
  --set clock update_freq=10 icon= script="$PLUGIN_DIR/clock.sh"

# Battery — only drawn on the MacBook display (undocked); the icon reflects the
# charge level and click reveals the exact percentage. Hidden when docked
# (clamshell on AC). display_change re-runs it on undock/redock; system_woke
# refreshes after sleep.
sketchybar --add item battery right \
  --set battery update_freq=60 \
  label.drawing=off \
  click_script="$PLUGIN_DIR/battery_click.sh" \
  script="$PLUGIN_DIR/battery.sh" \
  --subscribe battery display_change system_woke

# Wi-Fi — only drawn on the MacBook display (undocked) and only when offline, as
# a "you have no connection" reminder; invisible whenever Wi-Fi is up or docked.
# wifi_change fires it on connect/disconnect; display_change/system_woke are
# backstops, plus a slow poll since a false "online" defeats the indicator.
sketchybar --add item wifi right \
  --set wifi update_freq=30 \
  drawing=off \
  script="$PLUGIN_DIR/wifi.sh" \
  --subscribe wifi wifi_change display_change system_woke

# VPN / Work Proxy status
# display_change re-runs the script on undock/redock so it can hide itself when
# idle on the MacBook display (see plugins/vpn.sh).
sketchybar --add event proxy_toggle
sketchybar --add item vpn right \
  --set vpn update_freq=10 \
  click_script="$PLUGIN_DIR/vpn_click.sh" \
  script="$PLUGIN_DIR/vpn.sh" \
  --subscribe vpn proxy_toggle display_change

# Volume
# display_change re-runs the script on undock/redock so the compact-vs-spacious
# label (driven by plugins/lib/display_mode.sh) updates without a full reload.
sketchybar --add item volume right \
  --set volume script="$PLUGIN_DIR/volume.sh" \
  click_script="$PLUGIN_DIR/volume_click.sh" \
  --subscribe volume volume_change display_change

