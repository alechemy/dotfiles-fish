# The runtime ~/.aerospace.toml is generated by scripts/aerospace-{auto,cycle}-gaps.sh.
# Letting stow link this file would conflict with those scripts' atomic
# write-then-rename pattern: mv replaces the symlink with a regular file on
# first invocation, breaking stow's tracking. Keep it out of stow's view; the
# gap scripts handle bootstrap from source on first run, and setup.sh seeds
# the runtime on fresh installs.
\.aerospace\.toml$
.*\.template
