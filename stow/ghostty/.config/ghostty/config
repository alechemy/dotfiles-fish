font-family = Operator Mono SSm Lig
font-size = 14.0
background-opacity = .90
background-blur = true
alpha-blending = linear-corrected
theme = Catppuccin Macchiato
cursor-style = bar
cursor-style-blink = false
adjust-cursor-thickness = 1
macos-icon = retro
shell-integration-features = no-cursor
macos-window-shadow = false
macos-option-as-alt = true
macos-titlebar-style = tabs
keybind = cmd+enter=text:\x1b[13;9u
keybind = shift+enter=text:\x1b\r
keybind = cmd+t=new_split:down
keybind = cmd+shift+t=new_tab
keybind = cmd+shift+h=goto_split:left
keybind = cmd+shift+j=goto_split:down
keybind = cmd+shift+k=goto_split:up
keybind = cmd+shift+l=goto_split:right
keybind = global:cmd+ctrl+alt+shift+t=toggle_quick_terminal
keybind = cmd+ctrl+r=text:\x03/exit\rclaude\x20--continue\r
quick-terminal-position = right
clipboard-paste-protection = false
notify-on-command-finish = unfocused
notify-on-command-finish-action = notify
notify-on-command-finish-after = 10s
auto-update = off
