#!/usr/bin/env bash
# Opt-in comment stripper for Claude Code `Stop` and Copilot CLI `agentStop` hooks.
#
# Reads the hook JSON on stdin (both tools expose `.cwd` and a transcript path) and
# only acts when the working tree's git repo carries a root .uncommentrc.toml — the
# per-repo opt-in marker. Always exits 0 so it never blocks or fails the agent's turn.
#
# Scoping is two-dimensional, because `uncomment` itself is whole-file:
#   files — the exact edit targets from the just-ended turn, read from the transcript
#     (everything after the last real user prompt). Dirtiness vs HEAD is not required,
#     so work the agent commits mid-turn is still processed; earlier turns are out of
#     scope, so a comment the user reviewed or re-added is never re-stripped. Copilot
#     transcripts yield referenced paths instead, intersected with git's changed
#     files; with no transcript it falls back to all changed files.
#   lines — each file is diffed against a baseline and only comments on lines the
#     agent added get stripped, by `uncomment-scoped`. The baseline is the pre-edit
#     content the transcript recorded for that file in the turn (`originalFile`), so
#     uncommitted work that predates the turn is protected too; failing that, its
#     HEAD blob; failing that (new file), empty.
#
# Enable a repo with `comment-gate-init` (drops the marker + the commit-gate recipe).

set -u

input=$(cat 2>/dev/null || true)

cwd=$(printf '%s' "$input" | jq -r '.cwd // empty' 2>/dev/null || true)
{ [ -n "$cwd" ] && [ -d "$cwd" ]; } || cwd=$PWD
transcript=$(printf '%s' "$input" | jq -r '.transcript_path // .transcriptPath // empty' 2>/dev/null || true)

command -v git >/dev/null 2>&1 || exit 0

root=$(git -C "$cwd" rev-parse --show-toplevel 2>/dev/null) || exit 0
[ -f "$root/.uncommentrc.toml" ] || exit 0

# Turn start = timestamp of the last real user prompt (string content, or an array
# with no tool_result items; isMeta entries are hook/system injections, not prompts).
turn_start=""
edited=""
if [ -n "$transcript" ] && [ -f "$transcript" ]; then
  turn_start=$(jq -r '
    select(.type=="user" and ((.isMeta // false) | not))
    | select(.message.content
        | (type=="string") or (type=="array" and ([.[]?.type] | index("tool_result") | not)))
    | .timestamp // empty
  ' "$transcript" 2>/dev/null | tail -n 1)
  edited=$(jq -r --arg ts "$turn_start" '
    select(.type=="assistant" and ($ts=="" or .timestamp >= $ts))
    | .message.content[]?
    | select(.type=="tool_use" and (.name|test("^(Edit|Write|MultiEdit|NotebookEdit)$")))
    | (.input.file_path // .input.notebook_path // empty)
  ' "$transcript" 2>/dev/null | sort -u)
fi

files=()
if [ -n "$edited" ]; then
  while IFS= read -r f; do
    case $f in
      "$root/.uncommentrc.toml") continue ;;
      "$root"/*) ;;
      *) continue ;;
    esac
    [ -f "$f" ] && files+=("$f")
  done <<<"$edited"
else
  # No exact edit targets: fall back to git's changed files (tracked vs HEAD +
  # untracked, minus the marker), intersected with paths the transcript references
  # (Copilot); with no transcript at all, every changed file.
  candidates=()
  while IFS= read -r -d '' f; do
    [ -n "$f" ] || continue
    [ "$f" = ".uncommentrc.toml" ] && continue
    [ -f "$root/$f" ] && candidates+=("$root/$f")
  done < <(
    { git -C "$root" diff --name-only -z HEAD 2>/dev/null || true
      git -C "$root" ls-files --others --exclude-standard -z 2>/dev/null || true; }
  )
  if [ -n "$transcript" ] && [ -f "$transcript" ]; then
    for c in ${candidates[@]+"${candidates[@]}"}; do
      rel="${c#"$root"/}"
      { grep -qF -- "$c" "$transcript" 2>/dev/null || grep -qF -- "$rel" "$transcript" 2>/dev/null; } && files+=("$c")
    done
  else
    files=(${candidates[@]+"${candidates[@]}"})
  fi
fi
[ "${#files[@]}" -gt 0 ] || exit 0

# Pre-edit content per file, first write in the turn wins: Claude Code records it on
# every Edit/Write tool result. Base64 keeps the embedded newlines on one line.
baselines=""
if [ -n "$edited" ]; then
  baselines=$(jq -r --arg ts "$turn_start" '
    select(.toolUseResult | type=="object")
    | select($ts=="" or .timestamp >= $ts)
    | select(.toolUseResult.structuredPatch != null and .toolUseResult.filePath != null)
    | [.toolUseResult.filePath, (.toolUseResult.originalFile // "" | @base64)] | @tsv
  ' "$transcript" 2>/dev/null | awk -F'\t' '!seen[$1]++')
fi

# Built-in preservation (TODO/FIXME/doc/pragmas) plus a standing keep-set; honor an
# optional `remove_docs = true` line in the repo marker.
args=(-i IMPORTANT -i NOTE -i WARNING -i SAFETY -i SECURITY -i keep)
if grep -Eq '^[[:space:]]*remove_docs[[:space:]]*=[[:space:]]*true' "$root/.uncommentrc.toml" 2>/dev/null; then
  args+=(--remove-doc)
fi

tmpdir=$(mktemp -d) || exit 0
trap 'rm -rf "$tmpdir"' EXIT

py=$(command -v python3 2>/dev/null || true)
[ -x "$py" ] || py=/usr/bin/python3

n=0
for f in "${files[@]}"; do
  base="$tmpdir/base.$((n += 1))"
  b64=$(printf '%s\n' "$baselines" |
    awk -F'\t' -v p="$f" '$1==p {print $2; found=1; exit} END {exit !found}') &&
    printf '%s' "$b64" | base64 -d >"$base" 2>/dev/null ||
    git -C "$root" show "HEAD:${f#"$root"/}" >"$base" 2>/dev/null ||
    : >"$base"
  "$py" "$HOME/.local/bin/uncomment-scoped" "$base" "$f" "${args[@]}" >/dev/null 2>&1 || true
done
exit 0
