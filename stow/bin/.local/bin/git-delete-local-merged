#!/usr/bin/env fish

function log
    echo (set_color --bold magenta) "$argv" (set_color normal)
end

set main_branch (git main-branch)
if not git rev-parse --verify --quiet $main_branch >/dev/null
    echo "git-delete-local-merged: branch '$main_branch' does not exist" >&2
    exit 1
end
set current_branch (git branch --show-current)
if test -z "$current_branch"
    set current_branch $main_branch
end

log "Removing merged branches..."
set branches (git branch --merged $main_branch --format='%(refname:short)' | string match -v $main_branch | string match -v $current_branch)
if test (count $branches) -gt 0
    git branch -d $branches
end

log "Removing branches squashed or merged into $main_branch..."
git for-each-ref refs/heads/ --format="%(refname:short)" | while read branch
    if test "$branch" = "$main_branch"; or test "$branch" = "$current_branch"
        continue
    end
    set base (git merge-base $main_branch $branch)
    set hash (git rev-parse "$branch^{tree}")
    set commit (git commit-tree $hash -p $base -m _)
    set cherry (git cherry $main_branch $commit)
    if test "$cherry" = "- $commit"
        git branch -D $branch
    end
end
