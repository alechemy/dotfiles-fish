{
  // ============================================================================
  // UI LAYOUT & PANELS
  // ============================================================================
  "toolbar": {
    "code_actions": false
  },
  "git_panel": {
    "sort_by_path": false,
    "dock": "right",
    "default_width": 550,
    "status_style": "label_color"
  },
  "project_panel": {
    "hide_root": true,
    "dock": "right",
    "default_width": 500
  },
  "title_bar": {
    "show_sign_in": false
  },
  "tabs": {
    "file_icons": true,
    "git_status": true
  },
  "minimap": {
    "max_width_columns": 80,
    "show": "never"
  },

  // ============================================================================
  // TABS & TAB BAR
  // ============================================================================
  "max_tabs": 5,

  // ============================================================================
  // THEME & APPEARANCE
  // ============================================================================
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Night Owl"
  },
  "icon_theme": "VSCode Icons for Zed (Dark Angular)",

  // ============================================================================
  // FONTS & FONT SIZES
  // ============================================================================
  "buffer_font_family": "Operator Mono SSm Lig",
  "buffer_font_size": 14.0,
  "ui_font_size": 16.0,
  "ui_font_weight": 400.0,
  "agent_buffer_font_size": 12.0,
  "agent_ui_font_size": 16.0,

  // ============================================================================
  // EDITOR BEHAVIOR
  // ============================================================================
  "restore_on_startup": "launchpad",
  "hover_popover_enabled": true,
  "show_completion_documentation": true,
  "current_line_highlight": "all",
  "linked_edits": true,
  "show_whitespaces": "boundary",
  "soft_wrap": "editor_width",
  "wrap_guides": [80],
  "gutter": {
    "min_line_number_digits": 4
  },
  "excerpt_context_lines": 4,
  "rounded_selection": false,
  "colorize_brackets": true,
  "file_types": {},

  // ============================================================================
  // CODE FORMATTING & ACTIONS
  // ============================================================================
  "format_on_save": "on",
  "prettier": {
    "allowed": true
  },
  "inline_code_actions": true,

  // ============================================================================
  // SEARCH
  // ============================================================================
  "seed_search_query_from_cursor": "never",
  "use_smartcase_search": true,
  "search": {
    "center_on_match": true,
    "include_ignored": false
  },

  // ============================================================================
  // AI & EDITING FEATURES
  // ============================================================================
  "show_edit_predictions": true,
  "edit_predictions": {
    "mode": "subtle"
  },
  "agent": {
    "flexible": false,
    "use_modifier_to_send": true,
    "enable_feedback": false,
    "sidebar_side": "right",
    "dock": "right",
    "default_profile": "write",
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "gemini-3.1-pro-preview",
        "enable_thinking": false
      },
      {
        "provider": "copilot_chat",
        "model": "claude-opus-4.6",
        "enable_thinking": false
      },
      {
        "provider": "copilot_chat",
        "model": "claude-sonnet-4.6",
        "enable_thinking": false
      },
      {
        "provider": "google",
        "model": "gemini-3.1-pro-preview",
        "enable_thinking": false
      }
    ],
    "tool_permissions": {
      "tools": {
        "delete_path": {
          "default": "allow"
        },
        "restore_file_from_disk": {
          "default": "allow"
        },
        "move_path": {
          "default": "allow"
        },
        "fetch": {
          "default": "allow"
        },
        "edit_file": {
          "default": "allow"
        },
        "create_directory": {
          "default": "allow"
        },
        "mcp:angular-cli:find_examples": {
          "default": "allow"
        },
        "terminal": {
          "default": "allow"
        }
      }
    },
    "model_parameters": []
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
      "env": {
        "CLAUDE_CODE_EXECUTABLE": "/Users/alec/.local/bin/claude",
        "GIT_PAGER": "cat"
      },
      "default_config_options": {
        "mode": "bypassPermissions"
      },
      "favorite_config_option_values": {
        "model": ["opus"],
        "mode": ["bypassPermissions"]
      }
    },
    "Claude Code by Rohan Patra": {
      "type": "custom",
      "command": "node",
      "args": ["/Users/alec/Developer/claude-agent-acp/dist/index.js"],
      "default_config_options": {
        "model": "default",
        "effort_level": "xhigh",
        "mode": "bypassPermissions"
      },
      "favorite_config_option_values": {
        "model": ["opus"]
      }
    }
  },
  "context_servers": {
    "nx-mcp": {
      "command": "npx",
      "args": ["nx-mcp@latest"]
    },
    "mcp-server-context7": {
      "settings": {
        "context7_api_key": "op://Private/25nqmf6ljgb6ry5aowcegxabpa/credential"
      }
    },
    "angular-cli": {
      "command": "npx",
      "args": ["-y", "@angular/cli", "mcp", "-E", "modernize"]
    }
  },

  // ============================================================================
  // LANGUAGE MODELS & AI
  // ============================================================================
  "language_models": {
    "openai_compatible": {
      "NVIDIA": {
        "api_url": "https://integrate.api.nvidia.com/v1",
        "available_models": [
          {
            "name": "z-ai/glm5",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false
            }
          }
        ]
      }
    }
  },

  // ============================================================================
  // LANGUAGE SERVER PROTOCOL (LSP)
  // ============================================================================
  "lsp": {
    "stylelint-lsp": {
      "settings": {
        "stylelint": {
          "validate": ["css", "postcss", "scss"]
        }
      }
    }
  },

  // ============================================================================
  // LANGUAGE-SPECIFIC SETTINGS
  // ============================================================================
  "languages": {
    "Angular": {
      "formatter": [
        { "code_action": "source.fixAll.eslint" },
        { "code_action": "source.organizeImports" },
        {
          "external": {
            "command": "npx",
            "arguments": [
              "--no-install",
              "prettier",
              "--stdin-filepath",
              "{buffer_path}"
            ]
          }
        }
      ]
    },
    "JavaScript": {
      "formatter": [
        { "code_action": "source.fixAll.eslint" },
        { "code_action": "source.organizeImports" },
        {
          "external": {
            "command": "npx",
            "arguments": [
              "--no-install",
              "prettier",
              "--stdin-filepath",
              "{buffer_path}"
            ]
          }
        }
      ]
    },
    "TypeScript": {
      "formatter": [
        { "code_action": "source.fixAll.eslint" },
        { "code_action": "source.organizeImports" },
        {
          "external": {
            "command": "npx",
            "arguments": [
              "--no-install",
              "prettier",
              "--stdin-filepath",
              "{buffer_path}"
            ]
          }
        }
      ]
    },
    "JSON": {
      "formatter": {
        "external": {
          "command": "npx",
          "arguments": [
            "--no-install",
            "prettier",
            "--stdin-filepath",
            "{buffer_path}"
          ]
        }
      }
    },
    "JSONC": {
      "formatter": {
        "external": {
          "command": "npx",
          "arguments": [
            "--no-install",
            "prettier",
            "--stdin-filepath",
            "{buffer_path}"
          ]
        }
      }
    },
    "CSS": {
      "code_actions_on_format": {
        "source.fixAll.stylelint": true
      }
    },
    "Markdown": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "/Users/alec/.local/bin/markdownlint-stdin-fix"
        }
      }
    },
    "Java": {
      "format_on_save": "off",
      "formatter": "language_server"
    },
    "SCSS": {
      "code_actions_on_format": {
        "source.fixAll.stylelint": true
      }
    }
  },

  // ============================================================================
  // TERMINAL
  // ============================================================================
  "terminal": {
    "font_size": 14.0,
    "font_family": "Operator Mono SSm Lig",
    "cursor_shape": "bar",
    "env": {
      "GIT_PAGER": "cat"
    }
  },

  // ============================================================================
  // SYSTEM & TELEMETRY
  // ============================================================================
  "session": {
    "trust_all_worktrees": true
  },
  "base_keymap": "VSCode",
  "use_system_path_prompts": false,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  }
}
