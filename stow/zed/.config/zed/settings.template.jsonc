{
  // ============================================================================
  // UI LAYOUT & PANELS
  // ============================================================================
  "toolbar": {
    "code_actions": false
  },
  "git_panel": {
    "sort_by_path": false,
    "dock": "right",
    "default_width": 550,
    "status_style": "label_color"
  },
  "project_panel": {
    "hide_root": true,
    "dock": "right",
    "default_width": 500
  },
  "minimap": {
    "max_width_columns": 80,
    "show": "never"
  },

  // ============================================================================
  // TABS & TAB BAR
  // ============================================================================
  "max_tabs": 5,

  // ============================================================================
  // THEME & APPEARANCE
  // ============================================================================
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Night Owl Dark"
  },
  "icon_theme": "VSCode Icons for Zed (Dark Angular)",
  "theme_overrides": {
    "Night Owl Dark": {
      "drop_target.background": "#7e57c273",
      "created": "#9ccc65cc",
      "modified": "#e2b93dcc",
      "deleted": "#eF5350cc",
      "editor.wrap_guide": "#102a44",
      "editor.active_line.background": "#28707d29",
      "editor.document_highlight.read_background": "#ffffff08",
      "editor.document_highlight.write_background": "#5f7e9779",
      "editor.subheader.background": "#0b2942",
      "element.background": "#011627",
      "error.background": "#011627",
      "error.border": "#5f7e97",
      "hint.background": "#011627",
      "hint.border": "#5f7e97",
      "link_text.hover": "#82aaff",
      "search.match_background": "#1085bb5d",
      "text.muted": "#89a4bb",
      "warning": "#b39554",
      "warning.background": "#011627",
      "warning.border": "#5f7e97",
      "syntax": {
        "boolean": {
          "color": "#ff5874",
          "font_style": null,
          "font_weight": null
        },
        "constructor": {
          "color": "#82aaff",
          "font_style": "normal",
          "font_weight": null
        },
        "constant": {
          "color": "#82aaff",
          "font_style": null,
          "font_weight": null
        },
        "constant.builtin": {
          "color": "#ff5874",
          "font_style": null,
          "font_weight": null
        },
        "embedded": {
          "color": "#d6deeb",
          "font_style": null,
          "font_weight": null
        },
        "function": {
          "color": "#82aaff",
          "font_style": "italic",
          "font_weight": null
        },
        "function.method": {
          "color": "#82aaff",
          "font_style": "italic",
          "font_weight": null
        },
        "keyword": {
          "color": "#c792ea",
          "font_style": "normal",
          "font_weight": null
        },
        "keyword.control": {
          "color": "#c792ea",
          "font_style": "normal",
          "font_weight": null
        },
        "operator": {
          "color": "#c792ea",
          "font_style": null,
          "font_weight": null
        },
        "property": {
          "color": "#d6deeb",
          "font_style": null,
          "font_weight": null
        },
        "punctuation.bracket": {
          "color": "#ffd602",
          "font_style": "normal",
          "font_weight": null
        },
        "punctuation.delimiter": {
          "color": "#d6deeb",
          "font_style": "normal",
          "font_weight": null
        },
        "punctuation.special": {
          "color": "#82aaff",
          "font_style": "italic",
          "font_weight": null
        },
        "type": {
          "color": "#ffcb8b",
          "font_style": null,
          "font_weight": null
        },
        "type.builtin": {
          "color": "#c5e478",
          "font_style": null,
          "font_weight": null
        },
        "variable": {
          "color": "#d6deeb",
          "font_style": null,
          "font_weight": null
        }
      },
      "players": [
        {
          "cursor": "#80a4c2",
          "selection": "#1d3b53"
        }
      ]
    }
  },

  // ============================================================================
  // FONTS & FONT SIZES
  // ============================================================================
  "buffer_font_family": "Operator Mono SSm Lig",
  "buffer_font_size": 14.0,
  "ui_font_size": 16.0,
  "ui_font_weight": 400.0,
  "agent_buffer_font_size": 12.0,
  "agent_ui_font_size": 16.0,

  // ============================================================================
  // EDITOR BEHAVIOR
  // ============================================================================
  "restore_on_startup": "launchpad",
  "hover_popover_enabled": true,
  "show_completion_documentation": true,
  "current_line_highlight": "all",
  "linked_edits": true,
  "show_whitespaces": "boundary",
  "soft_wrap": "editor_width",
  "wrap_guides": [80],
  "gutter": {
    "min_line_number_digits": 4
  },
  "excerpt_context_lines": 4,
  "rounded_selection": false,
  "file_types": {},

  // ============================================================================
  // CODE FORMATTING & ACTIONS
  // ============================================================================
  "format_on_save": "on",
  "prettier": {
    "allowed": true
  },
  "inline_code_actions": true,

  // ============================================================================
  // SEARCH
  // ============================================================================
  "seed_search_query_from_cursor": "never",
  "use_smartcase_search": true,
  "search": {
    "include_ignored": false
  },

  // ============================================================================
  // AI & EDITING FEATURES
  // ============================================================================
  "show_edit_predictions": true,
  "edit_predictions": {
    "mode": "subtle"
  },
  "agent": {
    "tool_permissions": {
      "tools": {
        "terminal": {
          "default": "allow"
        }
      }
    },
    "default_model": {
      "enable_thinking": true,
      "provider": "google",
      "model": "gemini-3.1-pro-preview"
    },
    "model_parameters": []
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
      "env": {
        "CLAUDE_CODE_EXECUTABLE": "/Users/alec/.local/bin/claude",
        "GIT_PAGER": "cat"
      },
      "default_config_options": {
        "mode": "bypassPermissions"
      },
      "favorite_config_option_values": {
        "mode": ["bypassPermissions"]
      }
    },
    "Claude Code by Rohan Patra": {
      "type": "custom",
      "command": "node",
      "args": ["/Users/alec/Developer/claude-agent-acp/dist/index.js"],
      "default_config_options": {
        "mode": "bypassPermissions"
      }
    }
  },
  "context_servers": {
    "nx-mcp": {
      "command": "npx",
      "args": ["nx-mcp@latest"]
    },
    "mcp-server-context7": {
      "settings": {
        "context7_api_key": "op://Private/25nqmf6ljgb6ry5aowcegxabpa/credential"
      }
    },
    "angular-cli": {
      "command": "npx",
      "args": ["-y", "@angular/cli", "mcp", "-E", "modernize"]
    }
  },

  // ============================================================================
  // LANGUAGE MODELS & AI
  // ============================================================================
  "language_models": {
    "openai_compatible": {
      "NVIDIA": {
        "api_url": "https://integrate.api.nvidia.com/v1",
        "available_models": [
          {
            "name": "z-ai/glm5",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false
            }
          }
        ]
      }
    }
  },

  // ============================================================================
  // LANGUAGE SERVER PROTOCOL (LSP)
  // ============================================================================
  "lsp": {
    "stylelint-lsp": {
      "settings": {
        "stylelint": {
          "validate": ["css", "postcss", "scss"]
        }
      }
    }
  },

  // ============================================================================
  // LANGUAGE-SPECIFIC SETTINGS
  // ============================================================================
  "languages": {
    "Angular": {
      "formatter": [
        { "code_action": "source.fixAll.eslint" },
        { "code_action": "source.organizeImports" },
        {
          "external": {
            "command": "npx",
            "arguments": [
              "--no-install",
              "prettier",
              "--stdin-filepath",
              "{buffer_path}"
            ]
          }
        }
      ]
    },
    "JavaScript": {
      "formatter": [
        { "code_action": "source.fixAll.eslint" },
        { "code_action": "source.organizeImports" },
        {
          "external": {
            "command": "npx",
            "arguments": [
              "--no-install",
              "prettier",
              "--stdin-filepath",
              "{buffer_path}"
            ]
          }
        }
      ]
    },
    "TypeScript": {
      "formatter": [
        { "code_action": "source.fixAll.eslint" },
        { "code_action": "source.organizeImports" },
        {
          "external": {
            "command": "npx",
            "arguments": [
              "--no-install",
              "prettier",
              "--stdin-filepath",
              "{buffer_path}"
            ]
          }
        }
      ]
    },
    "JSON": {
      "formatter": {
        "external": {
          "command": "npx",
          "arguments": [
            "--no-install",
            "prettier",
            "--stdin-filepath",
            "{buffer_path}"
          ]
        }
      }
    },
    "JSONC": {
      "formatter": {
        "external": {
          "command": "npx",
          "arguments": [
            "--no-install",
            "prettier",
            "--stdin-filepath",
            "{buffer_path}"
          ]
        }
      }
    },
    "CSS": {
      "code_actions_on_format": {
        "source.fixAll.stylelint": true
      }
    },
    "SCSS": {
      "code_actions_on_format": {
        "source.fixAll.stylelint": true
      }
    }
  },

  // ============================================================================
  // TERMINAL
  // ============================================================================
  "terminal": {
    "font_size": 14.0,
    "font_family": "Operator Mono SSm Lig",
    "cursor_shape": "bar",
    "env": {
      "GIT_PAGER": "cat"
    }
  },

  // ============================================================================
  // SYSTEM & TELEMETRY
  // ============================================================================
  "session": {
    "trust_all_worktrees": true
  },
  "base_keymap": "VSCode",
  "use_system_path_prompts": false,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  }
}
