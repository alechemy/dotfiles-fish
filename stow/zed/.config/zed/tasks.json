[
  {
    "label": "Open in Marked 2",
    "command": "marked",
    "args": ["$ZED_FILE"],
    "tags": ["markdown"],
    "reveal": "never",
    "hide": "on_success",
    "show_summary": false,
    "show_command": false
  },
  {
    "label": "Markdownlint Fix",
    "command": "/opt/homebrew/bin/markdownlint",
    "args": ["--fix", "--quiet", "$ZED_FILE"],
    "tags": ["markdown"]
  }
]
