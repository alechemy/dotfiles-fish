#!/usr/bin/env bash
#
# Secrets gate: scan every commit that is about to leave the machine and
# refuse the push on a finding (betterleaks, config in .betterleaks.toml).
# This is the authoritative gate — it covers commits made with --no-verify,
# by other tools, or before the pre-commit hook existed. For a false
# positive, add a `betterleaks:allow` comment or an allowlist entry in
# .betterleaks.toml and re-push. Installed via core.hooksPath by setup.sh.

command -v betterleaks >/dev/null 2>&1 || {
    echo "pre-push: betterleaks not installed; skipping secrets scan (brew install betterleaks)" >&2
    exit 0
}

zero=$(git hash-object --stdin </dev/null | tr '0-9a-f' '0')

status=0
while read -r _local_ref local_sha _remote_ref remote_sha; do
    [ "$local_sha" = "$zero" ] && continue
    if [ "$remote_sha" = "$zero" ]; then
        range="$local_sha --not --remotes"
    else
        range="$remote_sha..$local_sha"
    fi
    betterleaks git --no-banner --redact=85 -v --log-opts "$range" . || status=1
done

exit $status
